# =============================================
# APK Sentinel — Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Anthropic (Claude AI) — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-PASTE-YOUR-KEY-HERE

# Server
PORT=3000
NODE_ENV=development

# Redis (for BullMQ job queue — runs in Docker)
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant (vector database — runs in Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# File paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output
TOOLS_DIR=./tools
